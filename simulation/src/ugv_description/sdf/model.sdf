<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="husky_a200">
    <static>false</static>

    <!-- Ground truth pose publisher (world frame) -->
    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>false</publish_link_pose>
      <publish_collision_pose>false</publish_collision_pose>
      <publish_visual_pose>false</publish_visual_pose>
      <publish_nested_model_pose>false</publish_nested_model_pose>
      <publish_model_pose>true</publish_model_pose>
      <update_frequency>10</update_frequency>
    </plugin>

    <!-- ==================== BASE FOOTPRINT ==================== -->
    <link name="base_footprint"/>

    <!-- ==================== CHASSIS ==================== -->
    <!-- Husky A200: 990x670x390 mm, 50 kg -->
    <link name="base_link">
      <pose relative_to="base_footprint">0 0 0.165 0 0 0</pose>
      <inertial>
        <mass>50.0</mass>
        <inertia>
          <!-- Box inertia: m/12 * (h^2+d^2), etc. for 0.99x0.67x0.20 -->
          <ixx>1.924</ixx>
          <iyy>4.500</iyy>
          <izz>5.558</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Main body (lower dark chassis) -->
      <visual name="chassis_base_visual">
        <pose>0 0 -0.05 0 0 0</pose>
        <geometry>
          <box><size>0.99 0.67 0.15</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
      <!-- Top cover (yellow — RAL 1003 Husky) -->
      <visual name="chassis_top_visual">
        <pose>0 0 0.05 0 0 0</pose>
        <geometry>
          <box><size>0.80 0.60 0.05</size></box>
        </geometry>
        <material>
          <!-- RAL 1003 Signal Yellow: #F9A900 -->
          <ambient>0.976 0.663 0.0 1</ambient>
          <diffuse>0.976 0.663 0.0 1</diffuse>
        </material>
      </visual>
      <!-- Bumpers front/rear (dark) -->
      <visual name="bumper_front_visual">
        <pose>0.49 0 -0.05 0 0 0</pose>
        <geometry>
          <box><size>0.05 0.67 0.10</size></box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
      <visual name="bumper_rear_visual">
        <pose>-0.49 0 -0.05 0 0 0</pose>
        <geometry>
          <box><size>0.05 0.67 0.10</size></box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
      <collision name="chassis_collision">
        <geometry>
          <box><size>0.99 0.67 0.20</size></box>
        </geometry>
      </collision>
    </link>

    <joint name="base_footprint_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
    </joint>

    <!-- ==================== WHEELS (4-wheel skid steer) ==================== -->
    <!-- Husky: 330 mm diameter (radius 0.165 m), width 100 mm -->
    <!-- Wheel separation: 555 mm (track width) -->
    <!-- Wheelbase: 512 mm (front-rear axle distance) -->

    <!-- Front Left Wheel -->
    <link name="front_left_wheel">
      <pose relative_to="base_link">0.256 0.2775 -0.065 -1.5707963 0 0</pose>
      <inertial>
        <mass>2.5</mass>
        <inertia>
          <ixx>0.0181</ixx>
          <iyy>0.0181</iyy>
          <izz>0.0340</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.165</radius><length>0.10</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.165</radius><length>0.10</length></cylinder>
        </geometry>
        <surface>
          <friction><ode><mu>5.0</mu><mu2>3.0</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><min_depth>0.0</min_depth><max_vel>0.01</max_vel></ode></contact>
        </surface>
      </collision>
    </link>
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
      </axis>
    </joint>

    <!-- Front Right Wheel -->
    <link name="front_right_wheel">
      <pose relative_to="base_link">0.256 -0.2775 -0.065 -1.5707963 0 0</pose>
      <inertial>
        <mass>2.5</mass>
        <inertia>
          <ixx>0.0181</ixx>
          <iyy>0.0181</iyy>
          <izz>0.0340</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.165</radius><length>0.10</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.165</radius><length>0.10</length></cylinder>
        </geometry>
        <surface>
          <friction><ode><mu>5.0</mu><mu2>3.0</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><min_depth>0.0</min_depth><max_vel>0.01</max_vel></ode></contact>
        </surface>
      </collision>
    </link>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
      </axis>
    </joint>

    <!-- Rear Left Wheel -->
    <link name="rear_left_wheel">
      <pose relative_to="base_link">-0.256 0.2775 -0.065 -1.5707963 0 0</pose>
      <inertial>
        <mass>2.5</mass>
        <inertia>
          <ixx>0.0181</ixx>
          <iyy>0.0181</iyy>
          <izz>0.0340</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.165</radius><length>0.10</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.165</radius><length>0.10</length></cylinder>
        </geometry>
        <surface>
          <friction><ode><mu>5.0</mu><mu2>3.0</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><min_depth>0.0</min_depth><max_vel>0.01</max_vel></ode></contact>
        </surface>
      </collision>
    </link>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
      </axis>
    </joint>

    <!-- Rear Right Wheel -->
    <link name="rear_right_wheel">
      <pose relative_to="base_link">-0.256 -0.2775 -0.065 -1.5707963 0 0</pose>
      <inertial>
        <mass>2.5</mass>
        <inertia>
          <ixx>0.0181</ixx>
          <iyy>0.0181</iyy>
          <izz>0.0340</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.165</radius><length>0.10</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.165</radius><length>0.10</length></cylinder>
        </geometry>
        <surface>
          <friction><ode><mu>5.0</mu><mu2>3.0</mu2></ode></friction>
          <contact><ode><kp>1e6</kp><kd>100</kd><min_depth>0.0</min_depth><max_vel>0.01</max_vel></ode></contact>
        </surface>
      </collision>
    </link>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
      </axis>
    </joint>

    <!-- ==================== SENSOR ARCH (top rail) ==================== -->
    <link name="sensor_arch">
      <pose relative_to="base_link">0 0 0.13 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Left upright -->
      <visual name="arch_left">
        <pose>-0.25 0.30 0.05 0 0 0</pose>
        <geometry><box><size>0.03 0.03 0.10</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
      <!-- Right upright -->
      <visual name="arch_right">
        <pose>-0.25 -0.30 0.05 0 0 0</pose>
        <geometry><box><size>0.03 0.03 0.10</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
      <!-- Cross bar -->
      <visual name="arch_cross">
        <pose>-0.25 0 0.10 0 0 0</pose>
        <geometry><box><size>0.03 0.60 0.03</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
    </link>
    <joint name="sensor_arch_joint" type="fixed">
      <parent>base_link</parent>
      <child>sensor_arch</child>
    </joint>

    <!-- ==================== INTEL D435i RGBD CAMERA ==================== -->
    <!-- Mounted front-center, ~0.30 m above ground -->
    <link name="camera_link">
      <pose relative_to="base_link">0.48 0 0.05 0 0 0</pose>
      <inertial>
        <mass>0.072</mass>
        <inertia>
          <ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.00001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="camera_visual">
        <geometry><box><size>0.025 0.09 0.025</size></box></geometry>
        <material>
          <ambient>0.5 0.5 0.5 1</ambient>
          <diffuse>0.5 0.5 0.5 1</diffuse>
        </material>
      </visual>
      <collision name="camera_collision">
        <geometry><box><size>0.025 0.09 0.025</size></box></geometry>
      </collision>

      <!-- RGBD Camera: D435i depth specs -->
      <sensor name="rgbd_camera" type="rgbd_camera">
        <pose>0 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <topic>rgbd_camera</topic>
        <camera>
          <!-- D435i depth FOV: 85.2° horizontal -->
          <horizontal_fov>1.4870</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.4</near>
            <far>300.0</far>
          </clip>
          <depth_camera>
            <clip>
              <near>0.4</near>
              <far>10.0</far>
            </clip>
          </depth_camera>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.005</stddev>
          </noise>
          <lens>
            <intrinsics>
              <!-- D435i at 640x480 -->
              <fx>382.0</fx>
              <fy>382.0</fy>
              <cx>320.0</cx>
              <cy>240.0</cy>
              <s>0</s>
            </intrinsics>
          </lens>
        </camera>
      </sensor>

      <!-- D435i onboard IMU -->
      <sensor name="camera_imu" type="imu">
        <always_on>true</always_on>
        <update_rate>200</update_rate>
        <topic>camera_imu</topic>
      </sensor>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
    </joint>

    <!-- ==================== PHIDGETS SPATIAL 1042 IMU ==================== -->
    <!-- Mounted on top plate, center -->
    <link name="imu_link">
      <pose relative_to="base_link">0 0 0.08 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.000005</ixx><iyy>0.000005</iyy><izz>0.000005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="imu_visual">
        <geometry><box><size>0.036 0.036 0.012</size></box></geometry>
        <material>
          <ambient>0.0 0.4 0.0 1</ambient>
          <diffuse>0.0 0.5 0.0 1</diffuse>
        </material>
      </visual>

      <!-- Phidgets 1042: ±8g accel, ±2000°/s gyro, 250 Hz -->
      <sensor name="phidgets_imu" type="imu">
        <always_on>true</always_on>
        <update_rate>250</update_rate>
        <topic>imu/data</topic>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
    </joint>

    <!-- ==================== 2D LIDAR (sim only, for Nav2) ==================== -->
    <!-- Mounted on sensor arch top, center -->
    <link name="lidar_link">
      <pose relative_to="base_link">0 0 0.24 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="lidar_visual">
        <geometry><cylinder><radius>0.035</radius><length>0.04</length></cylinder></geometry>
        <material>
          <ambient>0.8 0.0 0.0 1</ambient>
          <diffuse>0.8 0.0 0.0 1</diffuse>
        </material>
      </visual>
      <collision name="lidar_collision">
        <geometry><cylinder><radius>0.035</radius><length>0.04</length></cylinder></geometry>
      </collision>

      <sensor name="gpu_lidar" type="gpu_lidar">
        <pose>0 0 0.02 0 0 0</pose>
        <always_on>false</always_on>
        <update_rate>0</update_rate>
        <topic>lidar</topic>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>0</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.08</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
    </joint>

    <!-- ==================== PLUGINS ==================== -->
    <!-- Skid-Steer Drive (4 wheels, left pair + right pair) -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.555</wheel_separation>
      <wheel_radius>0.165</wheel_radius>
      <max_linear_acceleration>0.5</max_linear_acceleration>
      <min_linear_acceleration>-0.5</min_linear_acceleration>
      <max_angular_acceleration>0.8</max_angular_acceleration>
      <min_angular_acceleration>-0.8</min_angular_acceleration>
      <max_linear_velocity>1.0</max_linear_velocity>
      <max_angular_velocity>1.0</max_angular_velocity>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>

    <!-- Joint State Publisher -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>

    <!-- ==================== CHASE CAMERA (3rd person) ==================== -->
    <!-- Behind and above robot, looking forward-down — like racing game view -->
    <link name="chase_camera_link">
      <pose relative_to="base_link">-2.5 0 1.8 0 0.35 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia>
      </inertial>
      <sensor name="chase_camera" type="camera">
        <always_on>1</always_on>
        <update_rate>2</update_rate>
        <camera>
          <horizontal_fov>1.4</horizontal_fov>
          <image><width>160</width><height>90</height></image>
          <clip><near>0.3</near><far>150</far></clip>
        </camera>
        <topic>chase_camera/image</topic>
      </sensor>
    </link>
    <joint name="chase_camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>chase_camera_link</child>
    </joint>

  </model>
</sdf>
